   "source": [
    "### V de Cramér"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "PQ86ahU8g14j",
   "metadata": {
    "id": "PQ86ahU8g14j"
   },
   "outputs": [],
   "source": [
    "def cramers_v(x, y):\n",
    "    \"\"\"Calcula el coeficiente V de Cramér según fórmula del Libro Blanco.\"\"\"\n",
    "    confusion_matrix = pd.crosstab(x, y)\n",
    "    # Paso 2: Obtener Chi-cuadrado con Scipy\n",
    "    chi2, p, dof, expected = chi2_contingency(confusion_matrix)\n",
    "    \n",
    "    # Paso 3: Cálculo manual con Numpy\n",
    "    n = confusion_matrix.sum().sum()\n",
    "    phi2 = chi2 / n\n",
    "    r, k = confusion_matrix.shape\n",
    "    return np.sqrt(phi2 / min(k - 1, r - 1))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d9d0c87f",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Aplicar V de Cramér en variables relevantes\n",
    "cramer_val = cramers_v(df['tipo_dispositivo'], df['region'])\n",
    "print(f'V de Cramér (Dispositivo vs Región): {cramer_val:.4f}')"
   ]
  },
